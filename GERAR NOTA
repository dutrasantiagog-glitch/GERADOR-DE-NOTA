<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gerador de Nota de Serviço</title>

<style>
body{
    font-family: Arial, sans-serif;
    background:#f2f2f2;
    padding:20px;
}

.container{
    max-width:600px;
    margin:auto;
    background:white;
    padding:20px;
    border-radius:8px;
    box-shadow:0 0 10px rgba(0,0,0,0.1);
}

h1{
    text-align:center;
}

input, textarea{
    width:100%;
    padding:10px;
    margin-bottom:10px;
    border:1px solid #ccc;
    border-radius:5px;
}

button{
    width:100%;
    padding:12px;
    border:none;
    border-radius:5px;
    background:#2e7d32;
    color:white;
    font-weight:bold;
    cursor:pointer;
    margin-top:5px;
}

button:hover{
    background:#1b5e20;
}

#nota{
    margin-top:20px;
    padding:15px;
    border:1px solid #000;
    background:white;
}

@media print{
    body *{
        visibility:hidden;
    }
    #nota, #nota *{
        visibility:visible;
    }
    #nota{
        position:absolute;
        left:0;
        top:0;
        width:100%;
    }
}
</style>
</head>

<body>

<div class="container">
<h1>Gerador de Nota de Serviço</h1>

<input type="text" id="empresa" placeholder="Nome da sua empresa">
<input type="text" id="cliente" placeholder="Nome do cliente">
<input type="text" id="documento" placeholder="CPF ou CNPJ">
<textarea id="descricao" placeholder="Descrição do serviço"></textarea>
<input type="number" id="valor" placeholder="Valor do serviço">

<button onclick="gerarNota()">Gerar Nota</button>
<button onclick="window.print()">Salvar ou Imprimir PDF</button>

<div id="nota"></div>
</div>

<script>
function gerarNota(){

    var empresa = document.getElementById("empresa").value;
    var cliente = document.getElementById("cliente").value;
    var documento = document.getElementById("documento").value;
    var descricao = document.getElementById("descricao").value;
    var valor = document.getElementById("valor").value;

    var data = new Date().toLocaleDateString();

    var conteudo = `
    <h2>Nota de Serviço</h2>
    <p><strong>Empresa:</strong> ${empresa}</p>
    <p><strong>Cliente:</strong> ${cliente}</p>
    <p><strong>CPF/CNPJ:</strong> ${documento}</p>
    <p><strong>Descrição:</strong> ${descricao}</p>
    <p><strong>Valor:</strong> R$ ${valor}</p>
    <p><strong>Data:</strong> ${data}</p>
    `;

    document.getElementById("nota").innerHTML = conteudo;
}
</script>

</body>
</html>
